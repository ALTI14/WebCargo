@{
    ViewData["Title"] = "Ana Sayfa";
}

<style>
    .hero {
        text-align: center;
        padding: 50px 20px;
    }

        .hero h1 {
            font-size: 48px;
            margin-bottom: 10px;
        }

        .hero p {
            font-size: 20px;
            color: gray;
        }

    .features {
        display: flex;
        justify-content: center;
        gap: 20px;
        flex-wrap: wrap;
        margin-top: 40px;
    }

    .card {
        width: 250px;
        padding: 20px;
        border: 1px solid #ddd;
        border-radius: 10px;
        background: white;
        box-shadow: 0 0 10px rgba(0,0,0,0.1);
        text-align: center;
        transition: 0.2s;
    }

        .card:hover {
            transform: translateY(-5px);
        }

        .card img {
            width: 100%;
            height: 150px;
            object-fit: cover;
            border-radius: 8px;
        }

        .card h3 {
            margin-top: 15px;
        }
</style>

<div class="hero">
    <h1>WebCargo</h1>

    <p>
        Modern Kargo Takip ve Yönetim Sistemi
    </p>
</div>

<div class="features">

    <div class="card">
        <img src="https://images.unsplash.com/photo-1601584115197-04ecc0da31d7?w=600"
             alt="Kamyon">

        <h3>Kargo Takibi</h3>

        <p>
            Kargoların güncel durumunu hızlı ve kolay şekilde takip edin.
        </p>
    </div>

    <div class="card">
        <img src="https://images.unsplash.com/photo-1553413077-190dd305871c?w=600"
             alt="Depo">

        <h3>Durum Güncellemeleri</h3>

        <p>
            Kargo hareketlerini anlık olarak görüntüleyin.
        </p>
    </div>

    <div class="card">
        <img src="https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?w=600"
             alt="Teslimat">

        <h3>E-Posta Bildirimleri</h3>

        <p>
            Teslimat ve durum değişikliklerinde otomatik bildirim alın.
        </p>
    </div>

</div>