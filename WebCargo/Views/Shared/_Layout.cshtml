<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - WebCargo</title>

    <link rel="icon"
      type="image/x-icon"
      href="~/shipped.ico" />

    <script type="importmap"></script>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/WebCargo.styles.css"
          asp-append-version="true" />
</head>

<body>

    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">

            <div class="container-fluid">

                <a class="navbar-brand"
                   asp-area=""
                   asp-controller="Home"
                   asp-action="Index">
                    WebCargo
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent"
                        aria-expanded="false"
                        aria-label="Toggle navigation">

                    <span class="navbar-toggler-icon"></span>

                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

    <ul class="navbar-nav flex-grow-1">

        <li class="nav-item">
            <a class="nav-link text-dark"
               asp-area=""
               asp-controller="Home"
               asp-action="Index">
                Ana Sayfa
            </a>
        </li>

        <li class="nav-item">
            <a class="nav-link text-dark"
               asp-area=""
               asp-controller="Home"
               asp-action="Privacy">
                Gizlilik Politikası
            </a>
        </li>

        @if (Context.Session.GetString("Role") != null)
        {
            <li class="nav-item">
                <a class="nav-link text-dark"
                   asp-controller="Cargo"
                   asp-action="Index">
                    Kargolar
                </a>
            </li>
        }

        @if (Context.Session.GetString("Role") == "Admin")
        {
            <li class="nav-item">
                <a class="nav-link text-dark"
                asp-controller="Users"
                asp-action="Index">
                 Kullanıcılar
            </a>
    </li>
}

    </ul>

    <ul class="navbar-nav">

        @if (Context.Session.GetString("Username") == null)
        {
            <li class="nav-item">
                <a class="nav-link text-dark"
                   asp-controller="Login"
                   asp-action="Index">
                    Giriş Yap
                </a>
            </li>
        }
        else
        {
            <li class="nav-item">
                <span class="nav-link text-dark">
                    Merhaba,
                    @Context.Session.GetString("Username")
                </span>
            </li>

            <li class="nav-item">
                <span class="nav-link text-dark px-0">
                    |
                </span>
            </li>

            <li class="nav-item">
                <a class="nav-link text-dark"
                   asp-controller="Login"
                   asp-action="Logout">
                    Çıkış Yap
                </a>
            </li>
        }

    </ul>

</div>

            </div>

        </nav>
    </header>

    <div class="container">

        <main role="main"
              class="pb-3">

            @RenderBody()

        </main>

    </div>

    <footer class="border-top footer text-muted">

        <div class="container">

            &copy; 2026 - WebCargo -
            <a asp-area=""
               asp-controller="Home"
               asp-action="Privacy">
                Gizlilik Politikası
            </a>

        </div>

    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js"
            asp-append-version="true"></script>

    @await RenderSectionAsync(
        "Scripts",
        required: false)

</body>
</html>