<style>
    .menuButton {
        background: #f5f5f5;
        color: black;
        border: 1px solid #bdbdbd;
        border-radius: 5px;
        transition: 0.2s;
    }

        .menuButton:hover {
            background: #222;
            color: white;
            cursor: pointer;
        }
</style>

<div style="
    width:340px;
    margin:auto;
    margin-top:100px;
    border:1px solid gray;
    padding:20px;
    border-radius:10px;">

    <h1>Kargo Oluştur</h1>

    <form asp-action="Create"
          method="post">

        <div>
            <label>Ad Soyad</label>
            <br />

            <input name="alici"
                   type="text"
                   required
                   style="width:100%;" />
        </div>

        <br />

        <div>
            <label>T.C. Kimlik No</label>
            <br />

            <input name="tc"
                   type="text"
                   required
                   minlength="11"
                   maxlength="11"
                   pattern="[0-9]{11}"
                   oninput="this.value=this.value.replace(/[^0-9]/g,'')"
                   style="width:100%;" />
        </div>

        <br />

        <div>
            <label>E-Posta</label>
            <br />

            <input name="email"
                   type="email"
                   required
                   style="width:100%;" />
        </div>

        <br />

        <div>
            <label>Adres</label>
            <br />

            <textarea name="adres"
                      rows="4"
                      required
                      style="width:100%;"></textarea>
        </div>

        <br />

        <button class="menuButton"
                type="submit"
                style="width:100%;">
            Oluştur
        </button>

        <br />
        <br />

        <button class="menuButton"
                type="button"
                onclick="location.href='/Cargo'"
                style="width:100%;">
            Kargolara Dön
        </button>

        @if (ViewBag.Error != null)
        {
            <div style="
                color:red;
                text-align:center;
                margin-bottom:10px;">
                @ViewBag.Error
            </div>
        }

    </form>

</div>