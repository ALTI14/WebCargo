@model List<WebCargo.Models.User>

<style>
    .menuButton {
        background: #f5f5f5;
        color: black;
        border: 1px solid black;
        transition: 0.2s;
        padding: 2px 10px;
        text-decoration: none;
        display: inline-block;
    }

        .menuButton:hover {
            background: #222;
            color: white;
            cursor: pointer;
        }
</style>

<div style="
    display:flex;
    justify-content:space-between;
    align-items:center;">

    <h1>Kullanıcı Yönetimi</h1>

    <div>
        Kullanıcı Türü:
        <b>@Context.Session.GetString("Role")</b>
    </div>

</div>

<hr />

@if (TempData["Success"] != null)
{
    <div style="
        background:#d4edda;
        color:#155724;
        border:1px solid #c3e6cb;
        padding:10px;
        margin-bottom:15px;">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div style="
        background:#f8d7da;
        color:#721c24;
        border:1px solid #f5c6cb;
        padding:10px;
        margin-bottom:15px;">
        @TempData["Error"]
    </div>
}

<div style="
    display:flex;
    justify-content:space-between;
    align-items:center;">

    <form method="get">

        <input type="text"
               name="search"
               placeholder="Email ara..." />

        <button class="menuButton"
                type="submit">
            Ara
        </button>

    </form>

    <form asp-action="Create"
          method="post"
          style="
        display:flex;
        gap:5px;">

        <input type="email"
               name="email"
               placeholder="Email ekle..."
               required />

        <button class="menuButton"
                type="submit">
            Ekle
        </button>

    </form>

</div>

<br />

@if (Model.Any())
{
    <table border="1" cellpadding="10">

        <tr>

            <th>Kullanıcı Adı</th>

            <th>Email</th>

            <th>TC</th>

            <th>Durum</th>

            <th style="text-align:center;">
                İşlemler
            </th>

        </tr>

        @foreach (var user in Model)
        {
            <tr>

                <td>

                    @if (string.IsNullOrWhiteSpace(
                   user.Username))
                    {
                        <span>-</span>
                    }
                    else
                    {
                        <span>@user.Username</span>
                    }

                </td>

                <td>
                    @user.Email
                </td>

                <td>

                    @if (string.IsNullOrWhiteSpace(
                        user.Tc))
                    {
                        <span>-</span>
                    }
                    else
                    {
                        <span>@user.Tc</span>
                    }

                </td>

                <td>

                    @if (string.IsNullOrWhiteSpace(
                   user.Username))
                    {
                        <span>Davetli</span>
                    }
                    else
                    {
                        <span>Kayıtlı</span>
                    }

                </td>

                <td>

                    <div style="
                        display:flex;
                        gap:5px;
                        align-items:center;">

                        <form asp-action="Delete"
                              method="post"
                              style="margin:0;">

                            <input type="hidden"
                                   name="id"
                                   value="@user.Id" />

                            <button class="menuButton"
                                    type="submit"
                                    onclick="return confirm('Kullanıcı silinsin mi?')">
                                Sil
                            </button>

                        </form>

                    </div>

                </td>

            </tr>
        }

    </table>

    <br />

    <div style="
        display:flex;
        justify-content:center;
        align-items:center;
        gap:10px;">

        @if (ViewBag.Page > 1)
        {
            <a class="menuButton"
               asp-route-page="@(ViewBag.Page - 1)">
                Önceki
            </a>
        }

        <span>
            Sayfa @ViewBag.Page
        </span>

        @if (ViewBag.HasNextPage)
        {
            <a class="menuButton"
               asp-route-page="@(ViewBag.Page + 1)">
                Sonraki
            </a>
        }

    </div>
}
else
{
    <div style="
        text-align:center;
        margin-top:20px;">
        Kullanıcı bulunamadı.
    </div>
}