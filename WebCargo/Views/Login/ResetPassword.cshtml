<h1>Şifre Sıfırla</h1>

<style>
    .menuButton {
        background: #f5f5f5;
        color: black;
        border: 1px solid black;
        transition: 0.2s;
    }

        .menuButton:hover {
            background: #222;
            color: white;
            cursor: pointer;
        }
</style>

<div style="
    width:340px;
    margin:auto;
    margin-top:100px;
    border:1px solid gray;
    padding:20px;
    border-radius:10px;">

    @if (ViewBag.Error != null)
    {
        <div style="
            color:red;
            text-align:center;
            margin-bottom:10px;">
            @ViewBag.Error
        </div>
    }

    @if (ViewBag.Message != null)
    {
        <div style="
            color:green;
            text-align:center;
            margin-bottom:10px;">
            @ViewBag.Message
        </div>
    }

    <form method="post">

        <div>
            <label>Yeni Şifre</label>
            <br />

            <input name="password"
                   type="password"
                   required
                   minlength="8"
                   style="width:100%;" />
        </div>

        <br />

        <div>
            <label>Yeni Şifre (Tekrar)</label>
            <br />

            <input name="passwordAgain"
                   type="password"
                   required
                   minlength="8"
                   style="width:100%;" />
        </div>

        <br />

        <button class="menuButton"
                type="submit"
                style="width:100%;">
            Şifreyi Güncelle
        </button>

    </form>

</div>