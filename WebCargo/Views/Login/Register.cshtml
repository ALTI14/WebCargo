<h1>Kayıt Ol</h1>

<script src="https://www.google.com/recaptcha/api.js" async defer></script>


<style>
    .menuButton {
    background: #f5f5f5;
    color: black;
    border: 1px solid #bdbdbd;
    border-radius: 5px;
    transition: 0.2s;
    }

    .menuButton:hover {
    background: #222;
    color: white;
    cursor: pointer;
    }
</style>

<div style="
    width:340px;
    margin:auto;
    margin-top:100px;
    border:1px solid gray;
    padding:20px;
    border-radius:10px;">

    <form method="post">

        <div>
            <label>Kullanıcı Adı</label>
            <br />

            <input name="username"
                   type="text"
                   required
                   minlength="3"
                   style="width:100%;" />
        </div>

        <br />

        <div>
            <label>E-Posta</label>
            <br />

            <input name="email"
                   type="email"
                   required
                   style="width:100%;" />
        </div>

        <br />

        <div>
            <label>T.C. Kimlik No</label>
            <br />

            <input name="tc"
                   type="text"
                   required
                   minlength="11"
                   maxlength="11"
                   pattern="[0-9]{11}"
                   oninput="this.value=this.value.replace(/[^0-9]/g,'')"
                   style="width:100%;" />
        </div>

        <br />

        <div>
            <label>Şifre</label>
            <br />

            <input name="password"
                   type="password"
                   required
                   minlength="8"
                   style="width:100%;" />
        </div>

        <br />

        <div>
            <label>Şifre (Tekrar)</label>
            <br />

            <input name="passwordAgain"
                   type="password"
                   required
                   minlength="8"
                   style="width:100%;" />
        </div>

        <br />

        <div class="g-recaptcha"
             data-sitekey="@ViewBag.SiteKey"></div>

        <noscript>
            <div style="color:red;">
                Bu sayfayı kullanmak için JavaScript etkin olmalıdır.
            </div>
        </noscript>

        <br />

        @if (ViewBag.Error != null)
        {
            <div style="
                color:red;
                text-align:center;
                margin-bottom:10px;">
                @ViewBag.Error
            </div>
        }

        <div id="captchaError"
             style="color:red;display:none;margin-bottom:10px;">
            Lütfen captcha doğrulayın.
        </div>

        <button class="menuButton"
                type="submit"
                style="width:100%;">
            Kayıt Ol
        </button>

        <br />
        <br />

        <button class="menuButton"
                type="button"
                onclick="location.href='/Login'"
                style="width:100%;">
            Giriş Ekranına Dön
        </button>

    </form>

</div>

<script>
    document.querySelector("form")
    .addEventListener("submit", function (e)
    {
    if (grecaptcha.getResponse() == "")
    {
    e.preventDefault();

    document.getElementById("captchaError")
    .style.display = "block";
    }
    });
</script>